# Cache all static assets aggressively on Cloudflare
/wp-content/uploads/*
  Cache-Control: public, max-age=31536000, immutable

/wp-content/plugins/*
  Cache-Control: public, max-age=31536000, immutable

/wp-content/themes/*
  Cache-Control: public, max-age=31536000, immutable

/wp-includes/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages - short cache so updates deploy fast
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root pages
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff

# Security + performance headers on everything
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
